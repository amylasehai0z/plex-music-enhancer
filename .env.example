# OpenAI API key used by the OpenAI AI provider.
OPENAI_API_KEY=

# Plex server URL used by the Docker entrypoint as an alias for PLEX_ENHANCER_PLEX_URL.
PLEX_URL=http://plex:32400

# Plex authentication token used by the Docker entrypoint as an alias for PLEX_ENHANCER_PLEX_TOKEN.
PLEX_TOKEN=

# Internal web server port inside the container. Keep this at 8080 for Docker/Portainer.
PLEX_ENHANCER_WEB__PORT=8080

# Application log level. Common values: DEBUG, INFO, WARNING, ERROR.
PLEX_ENHANCER_LOG_LEVEL=INFO

# Container configuration directory. If this points to a directory, /config/.env is loaded.
PLEX_ENHANCER_CONFIG=/config

# Container cache directory for provider and knowledge cache data.
PLEX_ENHANCER_CACHE=/cache

# Optional explicit Plex settings for non-container usage.
PLEX_ENHANCER_PLEX_URL=
PLEX_ENHANCER_PLEX_TOKEN=

# Optional host port for docker-compose. The default maps host 1008 to container 8080.
PLEX_ENHANCER_HOST_PORT=1008
